class Solution {
public:
    string convertToBase7(int num) {
        if (num == 0)
            return "0";

        bool negative = num < 0;
        long long n = abs((long long)num);

        string result = "";

        while (n > 0) {
            result += char('0' + (n % 7));
            n /= 7;
        }

        if (negative)
            result += '-';

        reverse(result.begin(), result.end());

        return result;
    }
};
